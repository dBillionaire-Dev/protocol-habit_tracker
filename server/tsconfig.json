{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "rootDir": "..",
    "outDir": "./server/dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"]
    }
  },
  "include": [
    "*.ts",
    "auth/**/*.ts",
    "replit_integrations/**/*.ts",
    "../shared/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}